{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "process:default",
    "opener:allow-open-url",
    "opener:allow-default-urls"
  ]
}
